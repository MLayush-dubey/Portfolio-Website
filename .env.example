# Hosted open-source LLM via Cloudflare Workers AI.
# Copy this file to .env.local and fill the values there. Never commit real tokens.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/google/gemma-4-26b-a4b-it

# Optional for production rate limiting. Create a Redis database at https://console.upstash.com.
# Without these, local development falls back to an in-memory limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional metadata base. For Vercel this can be your generated https://*.vercel.app URL.
NEXT_PUBLIC_SITE_URL=
